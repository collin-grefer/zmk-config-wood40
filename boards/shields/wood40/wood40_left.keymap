#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &kp Y   &kp Z     &kp U     &kp A    &kp Q
                &kp C   &kp S     &kp I     &kp E    &kp O
                &kp V   &kp X     &kp U     &kp A    &kp ESC
                &trans  &kp MINUS &kp LSHFT &kp SPC  &kp TAB
            >;
        };
    };
};